#!/usr/bin/env sh

set -e

if [ ! -x "./node_modules/.bin/eslint" ]; then
  echo "pre-commit: eslint binary not found at ./node_modules/.bin/eslint"
  echo "Install dependencies before committing."
  exit 1
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|jsx|ts|tsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "pre-commit: running eslint --fix on staged JS/TS files"
printf '%s\n' "$STAGED_FILES" | xargs ./node_modules/.bin/eslint --fix

echo "pre-commit: re-staging files after eslint fixes"
printf '%s\n' "$STAGED_FILES" | xargs git add --

echo "pre-commit: verifying lint after fixes"
printf '%s\n' "$STAGED_FILES" | xargs ./node_modules/.bin/eslint
